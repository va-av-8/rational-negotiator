# API Keys - set ONE of these (OpenAI takes priority over OpenRouter)
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Model selection (optional)
# For OpenAI: gpt-4o-mini, gpt-4o, gpt-4-turbo
# For OpenRouter: openai/gpt-4o-mini, anthropic/claude-3.5-sonnet, etc.
LLM_MODEL=

# Server configuration (optional)
PORT=8080
HOST=0.0.0.0
