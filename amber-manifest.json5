{
  manifest_version: "0.2.0",
  program: {
    image: "ghcr.io/va-av-8/rational-negotiator:latest",
    entrypoint: "python main.py --host 0.0.0.0 --port 8080",
    env: {
      PYTHONUNBUFFERED: "1",
      OPENAI_API_KEY: "${secrets.OPENAI_API_KEY}",
    },
    network: {
      endpoints: [
        { name: "endpoint", port: 8080 },
      ],
    },
  },
  config_schema: {
    type: "object",
    properties: {},
    required: [],
    additionalProperties: false,
  },
  slots: {},
  provides: {
    a2a: { kind: "a2a", endpoint: "endpoint" },
  },
  exports: { a2a: "a2a" },
}
