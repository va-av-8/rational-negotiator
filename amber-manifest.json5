{
  manifest_version: "0.1.0",
  config_schema: {
    type: "object",
    properties: {
      openrouter_api_key: { type: "string", secret: true },
    },
    required: ["openrouter_api_key"],
    additionalProperties: false,
  },
  slots: {
    proxy: { kind: "a2a", optional: true },
  },
  program: {
    image: "ghcr.io/va-av-8/rational-negotiator:latest",
    entrypoint: "python main.py --host 0.0.0.0 --port 8080",
    env: {
      PYTHONUNBUFFERED: "1",
      OPENROUTER_API_KEY: "${config.openrouter_api_key}",
      LLM_MODEL: "mistralai/mistral-large-latest",
    },
    network: {
      endpoints: [
        { name: "a2a_endpoint", port 8080 },
      ],
    },
  },
  provides: {
    a2a: { kind: "a2a", endpoint: "a2a_endpoint" },
  },
  exports: { a2a: "a2a" },
}
