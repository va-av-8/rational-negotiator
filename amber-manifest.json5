{
  manifest_version: "0.1.0",
  config_schema: {
    type: "object",
    properties: {
      challenger_OPENAI_API_KEY: { type: "string" },
    },
    required: ["challenger_OPENAI_API_KEY"],
    additionalProperties: false,
  },
  slots: {},
  program: {
    image: "ghcr.io/va-av-8/rational-negotiator:latest",
    entrypoint: "python main.py --host 0.0.0.0 --port 8080",
    env: {
      PYTHONUNBUFFERED: "1",
      OPENAI_API_KEY: "${config.challenger_OPENAI_API_KEY}",
    },
    network: {
      endpoints: [
        { name: "a2a_endpoint", port: 8080 },
      ],
    },
  },
  provides: {
    a2a: { kind: "a2a", endpoint: "a2a_endpoint" },
  },
  exports: { a2a: "a2a" },
}
